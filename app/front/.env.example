# .env.example

# 是否使用 Mock 数据（true 时启用 MSW 与本地演示数据）
VITE_USE_MOCK=true

# API 配置示例
# VITE_API_URL=https://api.example.com

# 后端地址（直连后端时使用），例如：
# VITE_BACKEND_URL=http://127.0.0.1:8000

# API BaseURL（默认同源 /api；如需直连后端，可设为 ${VITE_BACKEND_URL}）
# VITE_API_BASE_URL=/api

# 应用配置示例
# VITE_APP_TITLE=Jellyfish Frontend

